{
  "openapi": "3.1.0",
  "info": {
    "title": "COMP3011 Fitness API",
    "description": "Fitness workout logging + analytics API (CRUD + insights).",
    "version": "0.3.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/workouts": {
      "post": {
        "tags": [
          "Workouts"
        ],
        "summary": "Create Workout",
        "operationId": "create_workout_workouts_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkoutCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkoutOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Workouts"
        ],
        "summary": "List Workouts",
        "operationId": "list_workouts_workouts_get",
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Skip"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkoutOut"
                  },
                  "title": "Response List Workouts Workouts Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/workouts/{workout_id}": {
      "get": {
        "tags": [
          "Workouts"
        ],
        "summary": "Get Workout",
        "operationId": "get_workout_workouts__workout_id__get",
        "parameters": [
          {
            "name": "workout_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Workout Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkoutOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Workouts"
        ],
        "summary": "Update Workout",
        "operationId": "update_workout_workouts__workout_id__put",
        "parameters": [
          {
            "name": "workout_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Workout Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkoutUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkoutOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Workouts"
        ],
        "summary": "Delete Workout",
        "operationId": "delete_workout_workouts__workout_id__delete",
        "parameters": [
          {
            "name": "workout_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Workout Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/analytics/streak": {
      "get": {
        "tags": [
          "Analytics"
        ],
        "summary": "Workout Streak",
        "description": "Calculates:\n- current_streak: consecutive days up to the most recent workout date\n- longest_streak: max consecutive-day run in the dataset",
        "operationId": "workout_streak_analytics_streak_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/analytics/weekly-summary": {
      "get": {
        "tags": [
          "Analytics"
        ],
        "summary": "Weekly Summary",
        "description": "Returns totals for workouts whose date is in [week_start, week_start+6].",
        "operationId": "weekly_summary_analytics_weekly_summary_get",
        "parameters": [
          {
            "name": "week_start",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Week start date (YYYY-MM-DD). Monday recommended.",
              "title": "Week Start"
            },
            "description": "Week start date (YYYY-MM-DD). Monday recommended."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "WorkoutCreate": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date",
            "description": "YYYY-MM-DD",
            "examples": [
              "2026-02-17"
            ]
          },
          "workout_type": {
            "type": "string",
            "title": "Workout Type",
            "examples": [
              "Push",
              "Pull",
              "Legs",
              "Cardio"
            ]
          },
          "duration_min": {
            "type": "integer",
            "maximum": 600.0,
            "minimum": 1.0,
            "title": "Duration Min"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 300
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "date",
          "workout_type",
          "duration_min"
        ],
        "title": "WorkoutCreate"
      },
      "WorkoutOut": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date",
            "description": "YYYY-MM-DD",
            "examples": [
              "2026-02-17"
            ]
          },
          "workout_type": {
            "type": "string",
            "title": "Workout Type",
            "examples": [
              "Push",
              "Pull",
              "Legs",
              "Cardio"
            ]
          },
          "duration_min": {
            "type": "integer",
            "maximum": 600.0,
            "minimum": 1.0,
            "title": "Duration Min"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 300
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          }
        },
        "type": "object",
        "required": [
          "date",
          "workout_type",
          "duration_min",
          "id"
        ],
        "title": "WorkoutOut"
      },
      "WorkoutUpdate": {
        "properties": {
          "date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date",
            "examples": [
              "2026-02-17"
            ]
          },
          "workout_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Workout Type"
          },
          "duration_min": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 600.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Min"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 300
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "title": "WorkoutUpdate"
      }
    }
  }
}